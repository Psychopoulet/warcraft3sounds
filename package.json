{

  "name": "warcraft3sounds",
  "version": "0.4.0",
  "description": "A basic API for Warcraft 3 sounds",

  "typings": "./lib/cjs/main.d.cts",
  "main": "./lib/cjs/main.cjs",
  "exports": {
    ".": {
      "require": {
        "types": "./lib/cjs/main.d.cts",
        "default": "./lib/cjs/main.cjs"
      }
    }
  },

  "scripts": {

    "prepare": "npx husky || true",

    "transpile-openapi": "npx openapi-typescript ./lib/data/descriptor.json -o ./lib/src/descriptor.ts",

    "lint-back": "npx eslint --config .eslintrc-back.js --ext .ts,.cts,.mts ./lib/src/**/*",
    "lint-front": "npx eslint --config .eslintrc-front.js --ext .ts,.tsx,.cts,.mts ./public/src/**/*",
    "lint-tests": "npx eslint --config .eslintrc-tests.js --ext .js,.cjs,.mjs ./test/**/*",
    "lint": "npm run lint-back && npm run lint-front && npm run lint-tests",

    "clean-back": "npx rimraf ./lib/cjs",
    "clean-front": "npx rimraf ./public/dist/bundle.js && npx rimraf ./public/dist/bundle.min.js && npx rimraf ./public/dist/bundle.min.js.map",
    "clean": "npm run clean-back && npm run clean-front",

    "build-back": "npm run-script clean-back && npm run-script transpile-openapi && npx tsc --project ./tsconfig.json",
    "build-front": "npm run-script clean-front && npm run-script transpile-openapi && npx webpack --config ./webpack.config.js",
    "build": "npm run-script build-back && npm run-script build-front",

    "check-requires": "npx used-deps-analyzer ./package.json ./lib/src --no-dev --overkill fs-extra node-promfs",
    "check-updates": "npx check-version-modules --no-fail-at-major --fail-at-minor --fail-at-patch",
    "unit-tests": "npm run-script build-back && npx nyc --reporter=html --reporter=text mocha && npx nyc report --reporter=text-lcov | coveralls",
    "tests": "npm run-script check-requires && npm run-script check-updates && npm run-script lint",

    "start": "node ./lib/cjs/main.cjs",

    "daemon-start": "npx pm2 start ./pm2.json",
    "daemon-restart": "npx pm2 reload ./pm2.json",
    "daemon-stop": "npx pm2 stop ./pm2.json && npx pm2 delete ./pm2.json",

    "docker-build": "docker image build --rm -t image-warcraft3sounds .",
    "docker-run": "docker container run -dti --name container-warcraft3sounds -p 8000:8000 image-warcraft3sounds",
    "docker-stop": "docker container stop container-warcraft3sounds && docker container remove -f container-warcraft3sounds",
    "docker-remove": "docker image remove -f image-warcraft3sounds"

  },

  "bin": {},
  "files": [
    "/bin",
    "/lib/cjs",
    "/public"
  ],
  "engines": {
    "node": ">=22.22.0"
  },

  "dependencies": {
    "compression": "1.8.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-openapi-validator": "5.6.2",
    "helmet": "8.1.0",
    "node-confmanager": "1.12.0",
    "node-forge": "1.4.0",
    "sqlite3": "6.0.1"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/node-forge": "1.3.14",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "check-version-modules": "2.3.0",
    "coveralls": "3.1.1",
    "eslint-plugin-personnallinter": "git+ssh://git@github.com/Psychopoulet/eslint-plugin-personnallinter",
    "husky": "9.1.7",
    "mocha": "11.7.5",
    "nyc": "18.0.0",
    "openapi-typescript": "7.13.0",
    "react": "19.2.5",
    "react-bootstrap-fontawesome": "git+ssh://git@github.com/Psychopoulet/react-bootstrap-fontawesome",
    "react-dom": "19.2.5",
    "rimraf": "6.1.3",
    "terser-webpack-plugin": "5.4.0",
    "ts-loader": "9.5.7",
    "typescript": "5.9.3",
    "used-deps-analyzer": "0.3.0",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2"
  },
  "optionalDependencies": {
    "pm2": "6.0.14"
  },

  "keywords": [
    "warcraft",
    "sounds",
    "reign of chaos",
    "frozen throne"
  ],
  "author": "Sébastien VIDAL",
  "contributors": [],
  "license": "ISC",
  "homepage": "https://github.com/Psychopoulet/warcraft3sounds#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/Psychopoulet/warcraft3sounds"
  },
  "bugs": {
    "url": "https://github.com/Psychopoulet/warcraft3sounds/issues"
  }

}
